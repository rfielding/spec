spec project_tooling

import "project_tooling.proto"

participants
  user
  browser
  specweb
  compiler
  graphviz
  openai
  repository

reliability
  user 0.999
  browser 0.995
  specweb parallel 0.999 0.999
  compiler 0.998
  graphviz 0.997
  openai parallel 0.995 0.995
  repository 0.999

conversation llm_design_workbench version 1 {
  start Editing

  assert evidence_before_answer: always(prompt_received -> mustEventually(evidence_ready or compile_failed))
  assert diagrams_possible: possibly(diagrams_ready)
  assert local_fallback_possible: possibly(local_response)
  assert llm_answer_possible: possibly(llm_answered)
  assert no_answer_without_evidence: always(llm_answered -> evidence_ready)
  assert save_possible: possibly(saved_files)

  inbox openai {
    capacity 200
  }

  state Editing {
    state_is editable_spec

    on user -> browser UserPrompt
      dwell_time_ms 5
      when msg.text != ""
      then PromptEntered chance 1.0
  }

  state PromptEntered {
    state_is prompt_received

    on browser -> specweb EditedFiles
      dwell_time_ms 15
      when msg.spec_path != ""
      then ServerReceived chance 1.0
  }

  state ServerReceived {
    state_is prompt_received

    on specweb -> compiler CompileRequest
      dwell_time_ms 8
      then Compiling chance 1.0
  }

  state Compiling {
    state_is prompt_received

    on compiler -> graphviz CompileEvidence
      dwell_time_ms 120
      when msg.spec_name != ""
      when msg.scenario_count != 0
      then RenderingDiagrams chance 0.9

    on compiler -> specweb CompileError
      dwell_time_ms 40
      when msg.message != ""
      then CompileFailed chance 0.1
  }

  state RenderingDiagrams {
    state_is evidence_ready

    on graphviz -> specweb EvidencePanelUpdate
      dwell_time_ms 200
      when msg.artifact_kind != ""
      then EvidenceReady chance 1.0
  }

  state EvidenceReady {
    state_is evidence_ready
    state_is diagrams_ready

    on specweb -> openai OpenAIRequest
      dwell_time_ms 25
      when msg.model != ""
      when msg.prompt != ""
      then AwaitingLLM chance 0.85

    on specweb -> browser AssistantText
      dwell_time_ms 10
      when msg.markdown != ""
      then LocalResponse chance 0.15
  }

  state AwaitingLLM {
    state_is evidence_ready

    on openai -> specweb AssistantText
      dwell_time_ms 5000
      when msg.markdown != ""
      then AssistantAnswered chance 0.78

    on openai -> specweb SpecPatchProposal
      dwell_time_ms 5200
      when msg.file_path != ""
      when msg.patch_text != ""
      then PatchSuggested chance 0.22
  }

  state AssistantAnswered {
    state_is evidence_ready
    state_is llm_answered

    on specweb -> browser AssistantText
      dwell_time_ms 12
      when msg.markdown != ""
      then AnswerDisplayed chance 1.0
  }

  state PatchSuggested {
    state_is evidence_ready
    state_is llm_answered

    on specweb -> browser SpecPatchProposal
      dwell_time_ms 12
      when msg.file_path != ""
      then AnswerDisplayed chance 1.0
  }

  state LocalResponse {
    state_is evidence_ready
    state_is local_response

    on specweb -> browser EvidencePanelUpdate
      dwell_time_ms 10
      when msg.title != ""
      then AnswerDisplayed chance 1.0
  }

  state CompileFailed {
    state_is compile_failed

    on specweb -> browser CompileError
      dwell_time_ms 10
      when msg.message != ""
      then ErrorDisplayed chance 1.0
  }

  state AnswerDisplayed {
    state_is evidence_ready
    state_is answer_displayed

    on browser -> repository EditedFiles
      dwell_time_ms 20
      when msg.spec_path != ""
      then SavingFiles chance 1.0
  }

  state SavingFiles {
    state_is evidence_ready

    on repository -> browser SaveResult
      dwell_time_ms 20
      when msg.file_path != ""
      then FilesSaved chance 1.0
  }

  state FilesSaved accept {
    state_is saved_files
  }

  state ErrorDisplayed accept
}
